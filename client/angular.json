{
  "$schema": "./node_modules/@angular/cli/lib/config/schema.json",
  "version": 1,
  "cli": {
    "packageManager": "npm"
  },
  "newProjectRoot": "projects",
  "projects": {
    "client": {
      "projectType": "application",
      "schematics": {},
      "root": "",
      "sourceRoot": "src",
      "prefix": "app",
      "architect": {
        "build": {
          "builder": "@angular/build:application",
          "options": {
            "browser": "src/main.ts",
            "tsConfig": "tsconfig.app.json",
            "assets": [
              {
                "glob": "**/*",
                "input": "public"
              }
            ],
            "styles": [
              "src/styles.css"
            ]
          },
          "configurations": {
            "production": {
              "budgets": [
                {
                  "type": "initial",
                  "maximumWarning": "500kB",
                  "maximumError": "1MB"
                },
                {
                  "type": "anyComponentStyle",
                  "maximumWarning": "4kB",
                  "maximumError": "8kB"
                }
              ],
              "outputHashing": "all",
              "fileReplacements": [
                {
                  "replace": "src/environments/environment.ts",
                  "with": "src/environments/environment.prod.ts"
                }
              ]
            },
            "development": {
              "optimization": false,
              "extractLicenses": false,
              "sourceMap": true
            },
            "email": {
              "server": "src/main.server.ts",
              "prerender": true,
              "ssr": {
                "entry": "src/server.ts"
              },
              "outputHashing": "none",
              "fileReplacements": [
                {
                  "replace": "src/app/services/match-data.service.ts",
                  "with": "src/app/services/match-data.email.service.ts"
                },
                {
                  "replace": "src/app/app.ts",
                  "with": "src/app/app.email.ts"
                },
                {
                  "replace": "src/app/components/footer/footer.component.ts",
                  "with": "src/app/components/footer/footer.email.component.ts"
                },
                {
                  "replace": "src/app/components/last-updated/last-updated.component.ts",
                  "with": "src/app/components/last-updated/last-updated.email.component.ts"
                }
              ]
            }
          },
          "defaultConfiguration": "production"
        },
        "serve": {
          "builder": "@angular/build:dev-server",
          "configurations": {
            "production": {
              "buildTarget": "client:build:production"
            },
            "development": {
              "buildTarget": "client:build:development"
            }
          },
          "defaultConfiguration": "development"
        },
        "test": {
          "builder": "@angular/build:unit-test"
        }
      }
    },
    "email-collector": {
      "projectType": "library",
      "root": "projects/email-collector",
      "sourceRoot": "projects/email-collector/src",
      "prefix": "ec",
      "architect": {
        "build": {
          "builder": "@angular/build:ng-packagr",
          "configurations": {
            "production": {
              "tsConfig": "projects/email-collector/tsconfig.lib.prod.json"
            },
            "development": {
              "tsConfig": "projects/email-collector/tsconfig.lib.json"
            }
          },
          "defaultConfiguration": "production"
        },
        "test": {
          "builder": "@angular/build:unit-test",
          "options": {
            "tsConfig": "projects/email-collector/tsconfig.spec.json"
          }
        }
      }
    }
  }
}
