{
  "name": "client",
  "version": "0.0.0",
  "scripts": {
    "ng": "ng",
    "start": "ng serve",
    "build": "ng build",
    "injectapi": "sed -i \"s|PLACEHOLDER_API_URL|$PLACEHOLDER_API_URL|g\" src/environments/environment.ts src/environments/environment.prod.ts",
    "build:prod": "npm run injectapi && ng build --configuration production",
    "build:lib": "ng build email-collector",
    "pack:lib": "cd dist/email-collector && npm pack",
    "build:pack": "npm run build:lib && npm run pack:lib",
    "build:all": "npm run build:lib && npm run build:prod",
    "watch": "ng build --watch --configuration development",
    "test": "ng test",
    "update-csp": "node scripts/update-csp-hash.js",
    "prettier:check": "prettier --check .",
    "prettier:fix": "prettier --write .",
    "serve:ssr:client": "node dist/client/server/server.mjs",
    "build:email": "ng build --configuration email",
    "preview:email": "npm run build:lib && npm run build:email && npx serve dist/client/browser -l 4201"
  },
  "private": true,
  "packageManager": "npm@11.6.2",
  "engines": {
    "node": ">= 24.0.0"
  },
  "dependencies": {
    "@angular/common": "^22.0.3",
    "@angular/compiler": "^22.0.3",
    "@angular/core": "^22.0.3",
    "@angular/forms": "^22.0.3",
    "@angular/platform-browser": "^22.0.3",
    "@angular/platform-server": "^22.0.3",
    "@angular/router": "^22.0.3",
    "@angular/ssr": "^22.0.4",
    "express": "^5.1.0",
    "rxjs": "~7.8.0",
    "tslib": "^2.3.0"
  },
  "devDependencies": {
    "@angular/build": "^22.0.4",
    "@angular/cli": "^22.0.4",
    "@angular/compiler-cli": "^22.0.3",
    "@tailwindcss/postcss": "^4.3.1",
    "@types/express": "^5.0.1",
    "@types/node": "^26.0.1",
    "@vitest/browser-playwright": "^4.1.9",
    "jsdom": "^29.1.1",
    "ng-packagr": "^22.0.0",
    "postcss": "^8.5.16",
    "prettier": "^3.9.1",
    "tailwindcss": "^4.3.1",
    "typescript": "~6.0.3",
    "vitest": "^4.0.8"
  }
}
